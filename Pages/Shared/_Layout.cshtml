<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SearchApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SearchApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav b-trwzjo4sto="" class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div b-trwzjo4sto="" class="container">
                <a class="navbar-brand" href="/">SearchApp</a>

                <div b-trwzjo4sto="" class="navbar-collapse d-sm-inline-flex justify-content-between collapse show" style="">
                    <ul b-trwzjo4sto="" class="navbar-nav flex-grow-1">
                        <li b-trwzjo4sto="" class="nav-item">
                            <a class="nav-link text-dark" href="/">Home</a>
                        </li>

                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="d-flex justify-content-around pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2023 - SearchApp
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>